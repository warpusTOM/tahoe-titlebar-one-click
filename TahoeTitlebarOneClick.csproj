<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>JhonLloydMolino.TahoeTitlebar</AssemblyName>
    <RootNamespace>TahoeTitlebarOneClick</RootNamespace>
    <Version>0.3.0</Version>
    <FileVersion>0.3.0.0</FileVersion>
    <AssemblyVersion>0.3.0.0</AssemblyVersion>
    <EmbedPrivateAssets Condition="'$(EmbedPrivateAssets)' == ''">false</EmbedPrivateAssets>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\TahoeTraffic.theme" Condition="'$(EmbedPrivateAssets)' == 'true' And Exists('Assets\TahoeTraffic.theme')" />
    <EmbeddedResource Include="Assets\TahoeTraffic.msstyles" Condition="'$(EmbedPrivateAssets)' == 'true' And Exists('Assets\TahoeTraffic.msstyles')" />
    <EmbeddedResource Include="Assets\ApplicationFrame.dll.patched" Condition="'$(EmbedPrivateAssets)' == 'true' And Exists('Assets\ApplicationFrame.dll.patched')" />
  </ItemGroup>

</Project>
